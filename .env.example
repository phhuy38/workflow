APP_NAME=workflow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Logging defaults (ADR-014)
LOG_CHANNEL=stack
LOG_STACK=daily,stderr
LOG_LEVEL=debug

# Database (ADR-001)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=workflow
DB_USERNAME=postgres
DB_PASSWORD=secret

# Redis (ADR-003)
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Mail (ADR-008)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@workflow.local
MAIL_FROM_NAME="${APP_NAME}"

# Reverb (ADR-002) - configure now, enable in Epic 4
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Admin Seeder (ADR-044)
ADMIN_EMAIL=admin@workflow.local
ADMIN_PASSWORD=changeme
ADMIN_NAME="System Admin"

# Session
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Testing & Dev
TELESCOPE_ENABLED=true

# Production (Override default values in prod)
# TELESCOPE_ENABLED=false
# APP_ENV=production
# APP_DEBUG=false
