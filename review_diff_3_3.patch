++class CompleteStep
++{
++    public function handle(StepExecution $step, User $user, array $data = []): void
++    {
++        DB::transaction(function () use ($step, $user, $data) {
++            // ADR-016: State transition
++            $step->status->transitionTo(StepCompleted::class);
++
++            $step->update([
