+    private function getTimeElapsed(): string
+    {
+        if (!$this->launched_at) {
+            return 'N/A';
+        }
+
+        $end = $this->completed_at ?? now();
+        $diff = $this->launched_at->diff($end);
+
+        $parts = [];
+        if ($diff->d > 0) $parts[] = $diff->d . ' ngày';
+        if ($diff->h > 0) $parts[] = $diff->h . ' giờ';
+        if ($diff->i > 0) $parts[] = $diff->i . ' phút';
+
+        return count($parts) > 0 ? implode(' ', $parts) : 'Dưới 1 phút';
+    }
+
+    private function getEstimatedRemainingHours(): int
+    {
+        $completedOrder = $this->stepExecutions
